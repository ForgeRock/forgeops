#!/usr/bin/env bash
# Run the am-config upgrade process on PingAM FBC configuration files.
#
# The default rules upgrade PingAM configuration to the same version as the upgrader image itself. For
# example, if the upgrader docker image is version 7.3.1, PingAM FBC files will be upgraded to 7.3.1.
#
# Usage: bin/am-upgrader [am-fbc-files] [rules-directory]
#  [am-fbc-files] is the directory that contains the exported PingAM FBC Files. This defaults to docker/am.
#   This script assumes FBC files have been previously exported.
#
#  If [rules-directory] is not provided, the version upgrade rules bundled in the image will be used. Otherwise
#  the rules found in this directory will be run.
#
#
# You can change the version of the upgrader used by supplying the REPO and TAG environment variables.
# For example:
# TAG=7.5.0 bin/am-config-upgrader

# Mac does not come with realpath by default.
# https://stackoverflow.com/questions/3572030/bash-script-absolute-path-with-os-x/18443300#18443300

set -e

# Grab our starting dir
start_dir=$(pwd)
# Figure out the dir we live in
SCRIPT_DIR=$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )
# Bring in our standard functions
source $SCRIPT_DIR/../../lib/shell/stdlib.sh
# Bring in common.sh
source $SCRIPT_DIR/common.sh
# Go back to where we started
cd "${start_dir}"

usage() {
  local usage_msg=$(cat<<EOM
usage: $PROG [OPTIONS] AM_CONF_PATH [RULES_PATH]

Upgrade AM file-based config (FBC) to selected version. It is also used to
apply placeholders to FBC.

Notes:
  * Default rules: /path/to/forgeops/etc/am-upgrader-rules/
  * Can provide profile name in docker/<component>/config-profiles
    or full path to profile
  * Can provide rules as a full path or relative to FORGEOPS_DATA/

OPTIONS:
  -h|--help                        : display usage and exit
  -d|--debug                       : turn on debugging
  --dryrun                         : do a dry run
  -v|--verbose                     : be verbose
  -b|--build-path <path>           : path to build dir (default: docker)

  # Mutually exclusive
  -l|--release-name <release-name> : release to use for base images
  -e|--env-name <env-name>         : forgeops env to use

Examples (prod env, prod profile):
  Normal operation (Profile name):
  $PROG -e prod prod

  Provide profile at a specific path:
  $PROG -e stage /path/to/my/profiles/stage

  Specify alternate rules file in FORGEOPS_DATA/my-rules/:
  $PROG -e prod prod my-rules

  Specify alternate rules at a specific path:
  $PROG -e prod prod /path/to/my-rules/

  Deprecated release file method:
  $PROG -l prod prod

  Do a dryrun:
  $PROG --dryrun -e prod prod

EOM
)

  usageStd $1 "$usage_msg" "$2"
}

realpath() {
    cd "$(dirname "$1")"
    local LINK=$(readlink "$(basename "$1")")
    while [ "$LINK" ]; do
        cd "$(dirname "$LINK")"
        local LINK=$(readlink "$(basename "$1")")
    done
    local REALPATH="$PWD/$(basename "$1")"
    cd "$start_dir"
    echo "$REALPATH"
}

ENV_REQUIRED=false

processArgs $*
checkContainerEngine

if [ "$DEBUG" = true ] ; then
  set -x
fi

CONFIG_DIR=
PROFILES_DIR=$BUILD_PATH/am/config-profiles
RULES_VOLUME=
if [ -n "$COMPONENTS" ] ; then
  CONFIG_PROF=${COMPONENTS[0]}
  if [[ "$CONFIG_PROF" =~ ^/ ]] ; then
    CONFIG_DIR=$CONFIG_PROF
  else
    CONFIG_DIR="${PROFILES_DIR}/${CONFIG_PROF}"
  fi
  # If the user supplies a rules volume use that instead of the builtin rules
  if [[ -n "${COMPONENTS[1]}" ]] ; then
    RULES_PATH=${COMPONENTS[1]}
    if [[ ! "$RULES_PATH" =~ ^/ ]] ; then
      if [ -d "${FORGEOPS_DATA}/${RULES_PATH}" ] ; then
        echo "Found rules in ${FORGEOPS_DATA}"
        RULES_PATH="${FORGEOPS_DATA}/${RULES_PATH}"
      elif [ -d "${ROOT_PATH}/${RULES_PATH}" ] ; then
        echo "Found rules in ${ROOT_PATH}"
        RULES_PATH="${ROOT_PATH}/${RULES_PATH}"
      fi
    fi
    RDIR=$(realpath $RULES_PATH)
    RULES_VOLUME="--volume $RDIR:/rules"
  fi
else
  usage 1 "You must provide a config-profile to upgrade"
fi

# Never run against a minikube daemon
## TODO update for podman with minikube
if [[ "$CONTAINER_ENGINE" == 'docker' ]] ; then
    $CONTAINER_ENGINE ps --format '{{.Names}}' | grep -q minikube \
        && unset -v DOCKER_HOST DOCKER_CERT_PATH DOCKER_MACHINE_NAME DOCKER_TLS_VERIFY
fi

# Check to see if your container engine is running
if ! $CONTAINER_ENGINE info --format ' ' ; then
    echo "A container engine must be running. Please start your container environment and run again."
    exit 1
fi

# The am upgrader image tag to run. To override:
# TAG=foo  bin/am-config-upgrader
TAG=${TAG:-latest}

if [ -n "$ENV_NAME" ] ; then
  HELM_ENV_PATH=$HELM_PATH/$ENV_NAME
  if [ -d "$HELM_ENV_PATH" ] ; then
    VALUES_PATH=$HELM_ENV_PATH/values.yaml
    if [ -f "$VALUES_PATH" ] ; then
      REPO=$(yq '.am_config_upgrader.image.repository' $VALUES_PATH)
      TAG=$(yq '.am_config_upgrader.image.tag' $VALUES_PATH)
    else
      usage 1 "Invalid environment.  Missing $VALUES_PATH."
    fi
  elif [ -d "$OVERLAY_PATH" ] ; then
    IMG_KUST_PATH=$OVERLAY_PATH/image-defaulter/kustomization.yaml
    if [ -f $IMG_KUST_PATH ] ; then
      REPO=$(yq '.images[] | select(.name == "am_config_upgrader") | .newName' $IMG_KUST_PATH)
      TAG=$(yq '.images[] | select(.name == "am_config_upgrader") | .newTag' $IMG_KUST_PATH)
    else
      usage 1 "Invalid environment.  Missing $IMG_KUST_PATH."
    fi
  fi
elif [ -n "$RELEASE_NAME" ] ; then
  # If we were given a release name, source the file if it exists to
  # override $REPO and $TAG from that file
  RELEASE_PATH=$BUILD_PATH/am-config-upgrader/releases/$RELEASE_NAME
  if [ -f $RELEASE_PATH ] ; then
    source $RELEASE_PATH
  else
    echo "Unable to find release $RELEASE_NAME in $RELEASE_PATH. Exiting."
    exit 1
  fi
fi

REPO=${REPO:-us-docker.pkg.dev/forgeops-public/images/am-config-upgrader}

# For docker volume mounts.
CONFIG=$(realpath $CONFIG_DIR)

# Run the upgrader locally - optionally over mounting the /rules directory
#set -x
CMD="$CONTAINER_ENGINE run --rm --user 0 --volume $CONFIG:/am-config $RULES_VOLUME $REPO:$TAG"
if [ "$DEBUG" = true ] ; then
  echo "DEBUG: Listing contents of volume mounts"
  $CMD ls /am-config
  $CMD ls /rules
fi
runOrPrint "$CMD"

SYSTEM=$(uname -s)
if [ "$SYSTEM" == "Linux" ] ; then
  echo "Detected Linux localhost, fixing local permissions. Requires sudo access."
  GID=$(id -g)
  runOrPrint "$CMD chown -R $UID:$GID /am-config/config"
fi
